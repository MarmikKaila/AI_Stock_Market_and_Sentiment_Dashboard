{
  "buildCommand": "npm install --prefix server && npm install --prefix client && npm run build --prefix client",
  "outputDirectory": "client/dist",
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "/api/:match*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "server/api/index.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
